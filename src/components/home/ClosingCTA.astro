---
import { cities } from "../../data/cities";
---

<section class="bg-ink text-paper">
  <div class="mx-auto max-w-6xl px-6 py-20 text-center">
    <h2 class="max-w-xl mx-auto h2-light">
      Your network shouldn't be something you have to think about.
    </h2>
    <p class="mt-4 text-paper/70 max-w-xl mx-auto">
      That's the job. One assessment, one design, one team that shows up and
      gets it right — so you can stop troubleshooting and start using your
      Wi-Fi.
    </p>
    <a
      href="/contact"
      class="mt-8 inline-block bg-signal text-paper font-medium px-8 py-3 rounded-lg hover:bg-signal/90 transition-colors"
    >
      Get a Free Quote
    </a>
    <p class="mt-6 font-mono text-xs uppercase tracking-wide text-paper/50">
      Home and Business Networks · Serving{" "}
      {
        cities.map((city, i) => (
          <>
            {i > 0 && (i === cities.length - 1 ? " and " : ", ")}
            {city.name}
          </>
        ))
      }
    </p>
  </div>
</section>
