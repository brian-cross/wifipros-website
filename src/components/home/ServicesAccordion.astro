---
import Bullet from "../Bullet.astro";

const categories = [
  {
    code: "NET",
    title: "Wi-Fi & Networking",
    sub: "Coverage that reaches every room, tuned right.",
    services: [
      {
        name: "Hardwired UniFi Access Points",
        desc: "Clean cabling and properly placed access points for fast, stable coverage in every room. Wireless mesh works too, if wiring isn't an option.",
      },
      {
        name: "Wi-Fi Optimization & Troubleshooting",
        desc: "Signal testing, interference checks, and access point tuning to fix slow or unreliable Wi-Fi — often without buying new hardware.",
      },
      {
        name: "Smart Home Device Integration",
        desc: "We connect your TVs, cameras, plugs, and bulbs, then split them onto their own network so they stop competing with your everyday internet.",
      },
    ],
  },
  {
    code: "CAB",
    title: "Structured Cabling",
    sub: "The wiring that everything else depends on.",
    services: [
      {
        name: "Ethernet Wiring & Termination",
        desc: "New cabling, or termination of what's already in your walls. No wiring option? We turn coax into gigabit Ethernet with MoCA adapters.",
      },
      {
        name: "New Home Consulting",
        desc: "Building a house? We tell your builder exactly where to run Ethernet — before the drywall goes up.",
      },
      {
        name: "Outbuilding Connectivity",
        desc: "Wireless point-to-point links or underground fibre to get your shop, barn, or garage online.",
      },
    ],
  },
  {
    code: "SEC",
    title: "Security & Access",
    sub: "See who's there. Control who gets in.",
    services: [
      {
        name: "Camera Surveillance",
        desc: "UniFi Protect cameras that record locally — no subscription, no cloud fees, and footage that stays yours.",
      },
      {
        name: "Building Door Access",
        desc: "Unlock doors with a phone, PIN, or card. No more cutting keys every time a tenant or employee changes.",
      },
    ],
  },
  {
    code: "SPC",
    title: "Specialty",
    sub: "Extras that build on a solid network.",
    services: [
      {
        name: "Integrated Audio Systems",
        desc: "Multi-zone, high-fidelity audio with AirPlay and Spotify Connect, built right into your network.",
      },
    ],
  },
];
---

<section class="border-t border-line">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <p
      class="font-mono text-xs uppercase tracking-wide text-signal flex items-center gap-2"
    >
      <Bullet pulse />
      What we do
    </p>
    <p class="mt-3 text-slate max-w-[60ch]">
      Four areas of work — tap a category to see what's included.
    </p>

    <div class="mt-8 grid gap-3.5" id="svc-accordion">
      {
        categories.map((cat, i) => (
          <div
            class="svc-card group border border-line rounded-xl overflow-hidden bg-paper data-[open=true]:border-signal/35"
            data-open={i === 0 ? "true" : "false"}
          >
            <button
              class="svc-card-head w-full flex items-center gap-4 px-5 py-5 text-left cursor-pointer focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-signal"
              aria-expanded={i === 0 ? "true" : "false"}
            >
              <span class="font-mono text-xs font-semibold text-slate bg-ink/5 border border-line rounded px-2 py-1 tracking-wide hidden sm:inline-block">
                {cat.code}
              </span>
              <Bullet size="md" />
              <span class="flex-1 min-w-0">
                <h3 class="font-display font-bold text-[19px] text-ink">
                  {cat.title}
                </h3>
                <p class="text-sm text-slate mt-0.5">{cat.sub}</p>
              </span>
              <span class="font-mono text-xs text-slate shrink-0 hidden sm:inline-block">
                {cat.services.length} service
                {cat.services.length > 1 ? "s" : ""}
              </span>
              <svg
                class="h-4.5 w-4.5 text-slate shrink-0 transition-transform duration-250 ease-out motion-reduce:transition-none group-data-[open=true]:rotate-180 group-data-[open=true]:text-signal"
                viewBox="0 0 20 20"
                fill="none"
              >
                <path
                  d="M5 7.5L10 12.5L15 7.5"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>
            <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 motion-reduce:transition-none group-data-[open=true]:grid-rows-[1fr]">
              <div class="overflow-hidden">
                <div class="flex flex-col gap-4 px-5 pb-5">
                  {cat.services.map((svc, j) => (
                    <div class="flex gap-3.5 pt-4 border-t border-line">
                      <span class="font-mono text-[11px] text-signal w-7 shrink-0 pt-0.5">
                        {String(j + 1).padStart(2, "0")}
                      </span>
                      <div>
                        <h4 class="font-display font-semibold text-[15px] text-ink">
                          {svc.name}
                        </h4>
                        <p class="text-sm text-slate leading-relaxed mt-1">
                          {svc.desc}
                        </p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const accordion = document.getElementById("svc-accordion");
  const buttons = accordion?.querySelectorAll(".svc-card-head");

  buttons?.forEach((button) => {
    button.addEventListener("click", () => {
      const card = button.closest(".svc-card");
      const isOpen = card?.getAttribute("data-open") === "true";
      card?.setAttribute("data-open", String(!isOpen));
      button.setAttribute("aria-expanded", String(!isOpen));
    });
  });
</script>
