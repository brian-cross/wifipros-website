---
import Bullet from "../Bullet.astro";
---

<section class="mx-auto max-w-6xl px-6 pt-20 pb-16">
  <p class="font-mono text-xs uppercase tracking-wide text-signal">
    Ubiquiti Network Specialists
  </p>
  <h1>Reliable Wi-Fi for Homes and Businesses in the Edmonton Area</h1>
  <p class="mt-5 text-slate max-w-2xl text-lg">
    Dead zones, dropped calls, and buffering aren't an internet problem —
    they're a network problem. We design and install enterprise-grade UniFi and
    UISP networks that actually reach every room, every outbuilding, every
    device.
  </p>
  <p
    class="mt-4 flex items-center gap-2 font-mono text-xs uppercase tracking-wide text-slate"
  >
    <Bullet pulse />
    Local technicians · Ubiquiti specialists · No subscriptions, no shortcuts
  </p>
  <div class="mt-8 flex flex-wrap gap-4">
    <a
      href="/contact"
      class="bg-signal text-paper font-medium px-6 py-3 rounded-lg hover:bg-signal/90 transition-colors"
    >
      Request a Quote
    </a>
    <a
      href="/contact"
      class="border border-line text-ink font-medium px-6 py-3 rounded-lg hover:bg-ink/5 transition-colors"
    >
      Contact Us
    </a>
  </div>
</section>
