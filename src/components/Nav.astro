---
import Bullet from "./Bullet.astro";

const links = [
  { href: "/", label: "Home" },
  {
    href: "/services",
    label: "Services",
    submenu: [
      {
        href: "/services/ubiquiti-network-design-installation",
        label: "Network Design & Installation",
      },
      {
        href: "/services/unifi-protect-camera-installation",
        label: "Camera Installation",
      },
      {
        href: "/services/smart-building",
        label: "Smart Building & Access",
      },
      {
        href: "/services/rural-acreage-internet-wifi-edmonton-area",
        label: "Rural & Acreage Connectivity",
      },
    ],
  },
  {
    href: "/service-areas",
    label: "Service Areas",
  },
  { href: "/contact", label: "Contact" },
];
const current = Astro.url.pathname;
const isActiveLink = (href: string) =>
  current === href || current.startsWith(`${href}/`);
const submenuId = (label: string) =>
  `mobile-submenu-${label.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`;
---

<nav class="relative">
  <!-- Desktop -->
  <ul
    class="hidden md:flex items-center gap-8 font-mono text-xs tracking-wide uppercase"
  >
    {
      links.map((link) => (
        <li class="relative group">
          <a
            href={link.href}
            class:list={[
              "relative py-2 text-slate transition-colors hover:text-ink",
              { "text-ink": isActiveLink(link.href) },
            ]}
          >
            {isActiveLink(link.href) && (
              <Bullet
                class="absolute -left-3.5 top-1/2 -translate-y-1/2"
                pulse
              />
            )}
            {link.label}
          </a>
          {link.submenu && (
            <ul class="absolute right-0 top-full mt-2 hidden min-w-70 rounded-lg border border-line bg-paper p-2 shadow-lg group-hover:block group-focus-within:block">
              {link.submenu.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      "block rounded px-3 py-2 text-[11px] tracking-wide text-slate transition-colors hover:bg-ink/5 hover:text-ink",
                      { "text-ink": current === item.href },
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))
    }
  </ul>

  <!-- Mobile toggle -->
  <button
    id="nav-toggle"
    class="md:hidden flex flex-col justify-center gap-1.5 h-10 w-10"
    aria-expanded="false"
    aria-controls="mobile-menu"
    aria-label="Toggle menu"
  >
    <span class="block h-0.5 w-6 bg-ink transition-transform"></span>
    <span class="block h-0.5 w-6 bg-ink transition-opacity"></span>
    <span class="block h-0.5 w-6 bg-ink transition-transform"></span>
  </button>

  <!-- Mobile panel -->
  <div
    id="mobile-menu"
    class="hidden md:hidden absolute right-0 top-full mt-2 w-56 bg-paper border border-line rounded-lg shadow-lg overflow-hidden"
  >
    <ul class="divide-y divide-line font-mono text-xs tracking-wide uppercase">
      {
        links.map((link) => (
          <li>
            {link.submenu ? (
              <>
                <button
                  type="button"
                  class="flex w-full items-center justify-between gap-2 px-4 py-3 text-left uppercase text-slate hover:bg-ink/5 hover:text-ink"
                  data-submenu-toggle
                  aria-expanded="false"
                  aria-controls={submenuId(link.label)}
                >
                  <span class="flex items-center gap-2">
                    {isActiveLink(link.href) && <Bullet pulse />}
                    {link.label}
                  </span>
                  <span class="text-[10px]">+</span>
                </button>
                <ul
                  id={submenuId(link.label)}
                  class="hidden bg-slate/5 px-4 pb-3"
                >
                  {link.submenu.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class:list={[
                          "block rounded px-3 py-2 text-[11px] tracking-wide text-slate hover:text-ink",
                          { "text-ink": current === item.href },
                        ]}
                      >
                        {item.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a
                href={link.href}
                class:list={[
                  "flex items-center gap-2 px-4 py-3 text-slate hover:bg-ink/5 hover:text-ink",
                  { "text-ink": isActiveLink(link.href) },
                ]}
              >
                {isActiveLink(link.href) && <Bullet pulse />}
                {link.label}
              </a>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.contains("hidden") === false;
    menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });

  document.querySelectorAll("[data-submenu-toggle]").forEach((button) => {
    button.addEventListener("click", () => {
      const submenuId = button.getAttribute("aria-controls");
      const submenu = submenuId ? document.getElementById(submenuId) : null;
      const isExpanded = button.getAttribute("aria-expanded") === "true";

      submenu?.classList.toggle("hidden");
      button.setAttribute("aria-expanded", String(!isExpanded));
    });
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      menu?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    }
  });

  document.addEventListener("click", (e) => {
    if (
      !menu?.contains(e.target as Node) &&
      !toggle?.contains(e.target as Node)
    ) {
      menu?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    }
  });
</script>
