---
const links = [
  { href: "/", label: "Home" },
  { href: "/service-areas", label: "Service Areas" },
  {
    href: "/services",
    label: "Services",
    submenu: [
      {
        href: "/services/ubiquiti-network-design-installation",
        label: "Network Design & Installation",
      },
      {
        href: "/services/unifi-protect-camera-installation",
        label: "Camera Installation",
      },
      {
        href: "/services/rural-acreage-internet-wifi-edmonton-area",
        label: "Rural & Acreage Connectivity",
      },
    ],
  },
  { href: "/contact", label: "Contact" },
];
const current = Astro.url.pathname;
const isActiveLink = (href: string) =>
  current === href || current.startsWith(`${href}/`);
---

<nav class="relative">
  <!-- Desktop -->
  <ul
    class="hidden md:flex items-center gap-8 font-mono text-xs tracking-wide uppercase"
  >
    {
      links.map((link) => (
        <li class="relative group">
          <a
            href={link.href}
            class:list={[
              "relative py-2 text-slate transition-colors hover:text-ink",
              { "text-ink": isActiveLink(link.href) },
            ]}
          >
            {isActiveLink(link.href) && (
              <span class="absolute -left-3.5 top-1/2 -translate-y-1/2 h-1.5 w-1.5 rounded-full bg-connect animate-pulse" />
            )}
            {link.label}
          </a>
          {link.submenu && (
            <ul class="absolute right-0 top-full mt-2 hidden min-w-70 rounded-lg border border-line bg-paper p-2 shadow-lg group-hover:block group-focus-within:block">
              {link.submenu.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      "block rounded px-3 py-2 text-[11px] tracking-wide text-slate transition-colors hover:bg-ink/5 hover:text-ink",
                      { "text-ink": current === item.href },
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))
    }
  </ul>

  <!-- Mobile toggle -->
  <button
    id="nav-toggle"
    class="md:hidden flex flex-col justify-center gap-1.5 h-10 w-10"
    aria-expanded="false"
    aria-controls="mobile-menu"
    aria-label="Toggle menu"
  >
    <span class="block h-0.5 w-6 bg-ink transition-transform"></span>
    <span class="block h-0.5 w-6 bg-ink transition-opacity"></span>
    <span class="block h-0.5 w-6 bg-ink transition-transform"></span>
  </button>

  <!-- Mobile panel -->
  <div
    id="mobile-menu"
    class="hidden md:hidden absolute right-0 top-full mt-2 w-56 bg-paper border border-line rounded-lg shadow-lg overflow-hidden"
  >
    <ul class="divide-y divide-line font-mono text-xs tracking-wide uppercase">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "flex items-center gap-2 px-4 py-3 text-slate hover:bg-ink/5 hover:text-ink",
                { "text-ink": isActiveLink(link.href) },
              ]}
            >
              {isActiveLink(link.href) && (
                <span class="h-1.5 w-1.5 rounded-full bg-connect animate-pulse" />
              )}
              {link.label}
            </a>
            {link.submenu && (
              <ul class="bg-slate/5 px-4 pb-3">
                {link.submenu.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        "block rounded px-3 py-2 text-[11px] tracking-wide text-slate hover:text-ink",
                        { "text-ink": current === item.href },
                      ]}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.contains("hidden") === false;
    menu?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      menu?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    }
  });

  document.addEventListener("click", (e) => {
    if (
      !menu?.contains(e.target as Node) &&
      !toggle?.contains(e.target as Node)
    ) {
      menu?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    }
  });
</script>
