---
const {
  variant = "light",
  border = true,
  class: className = "",
}: {
  variant?: "light" | "dark";
  border?: boolean;
  class?: string;
} = Astro.props;

const variants = {
  light: { bg: "bg-paper text-ink", border: "border-line" },
  dark: { bg: "bg-ink text-paper", border: "border-paper/10" },
};

const v = variants[variant];
---

<section class:list={[v.bg, border && ["border-t", v.border]]}>
  <div class:list={["mx-auto max-w-6xl px-6 py-16", className]}>
    <slot />
  </div>
</section>
