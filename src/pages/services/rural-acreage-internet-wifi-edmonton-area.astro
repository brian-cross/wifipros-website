---
import Bullet from "../../components/Bullet.astro";
import Eyebrow from "../../components/Eyebrow.astro";
import Layout from "../../components/layouts/Layout.astro";
import Section from "../../components/Section.astro";

const connectMethods = [
  {
    title: "Wireless Building-to-Building Bridges (Ubiquiti UISP)",
    description:
      "When trenching isn’t practical or a second building is too far or awkward to run cable to, we use Ubiquiti UISP wireless bridges to link your house, shop, barn, or guest suite with a fast, stable point-to-point connection.",
  },
  {
    title: "Underground Fibre Runs",
    description:
      "For permanent, maximum-reliability connections between buildings, we install buried fibre optic cabling. Fibre is immune to lightning-induced surges common on open acreage properties and delivers the most future-proof bandwidth available.",
  },
  {
    title: "Whole-Property Wi-Fi Coverage",
    description:
      "Once the backbone is in place, we design outdoor and indoor Wi-Fi coverage using Ubiquiti UniFi access points so signal reaches the yard, the shop, the barn, and anywhere else you need it.",
  },
  {
    title: "UniFi Protect Security Cameras for Acreages",
    description:
      "Rural properties benefit enormously from remote-viewable security cameras covering driveways, gates, outbuildings, and perimeter areas. We design UniFi Protect camera systems that run on the same network as your connectivity, recorded locally on a UniFi NVR.",
  },
];

const whyChooseUs = [
  "We understand rural properties, long distances, multiple structures, and limited existing infrastructure.",
  "We recommend the right tool for the terrain — wireless bridges, buried fibre, or a mix of both.",
  "We use enterprise-grade Ubiquiti hardware built for outdoor, multi-building deployments.",
  "We’re local to the Edmonton area and familiar with the surrounding acreage communities.",
];

const scenarios = [
  "Connecting a detached shop or barn to house internet and Wi-Fi",
  "Extending reliable Wi-Fi across several acres of yard space",
  "Linking a guest cabin, secondary suite, or rental unit to the main property network",
  "Replacing spotty or failing wireless setups from previous installers",
  "Adding remote-viewable security cameras at gates, driveways, and outbuildings",
  "Preparing new-build acreages for connectivity before or during construction",
];

const faqs = [
  {
    question: "How far apart can buildings be for a wireless bridge to work?",
    answer:
      "Ubiquiti UISP bridges can reliably cover distances well beyond what’s typical on most acreage properties, provided there’s a clear line of sight between antennas. We assess this on-site before recommending wireless over buried fibre.",
  },
  {
    question: "Is buried fibre more reliable than a wireless bridge?",
    answer:
      "Fibre is generally more resistant to weather and interference since it’s underground, but it requires trenching. Many properties do well with a wireless bridge, especially where trenching is costly or disruptive.",
  },
  {
    question: "Do you provide the internet service itself?",
    answer:
      "No — we design and install the network, cameras, and connectivity infrastructure. We can advise on which internet sources are available at your location, but the internet service itself comes from a separate provider.",
  },
  {
    question: "Can this handle a farm or acreage-based business?",
    answer:
      "Yes — we’ve designed networks for acreage properties with home-based businesses, shops, and outbuildings that need dependable, business-grade connectivity.",
  },
];
---

<Layout
  title="Rural & Acreage Connectivity | Wi-Fi Pros"
  description="Reliable internet and Wi-Fi solutions for rural properties, acreages, and multi-building sites across the Edmonton area."
>
  <Section border={false} class="pt-20">
    <Eyebrow> Rural & Acreage Connectivity </Eyebrow>
    <h1>Reliable Internet & Wi-Fi for Acreages and Rural Properties</h1>
    <p class="mt-5 text-slate max-w-xl text-lg">
      Living on an acreage shouldn’t mean settling for one weak router in the
      house and no signal in the shop, barn, or guest cabin. Wi-Fi Pros Network
      Consulting designs rural connectivity solutions purpose-built for the
      acreage lifestyle — connecting multiple buildings, covering large outdoor
      areas, and giving you the same reliability you’d expect in the city.
    </p>
    <Eyebrow class="mt-4 text-slate!">
      <Bullet pulse />
      Local rural specialists · Wireless bridges · Buried fibre · Whole-property Wi-Fi
    </Eyebrow>
    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href="/contact"
        class="bg-signal text-paper font-medium px-6 py-3 rounded-lg hover:bg-signal/90 transition-colors"
      >
        Book a Rural Site Assessment
      </a>
      <a
        href="/contact"
        class="border border-line text-ink font-medium px-6 py-3 rounded-lg hover:bg-ink/5 transition-colors"
      >
        Contact Us
      </a>
    </div>
  </Section>

  <Section>
    <h2>How We Connect Acreage Properties</h2>
    <div class="mt-8 space-y-6">
      {
        connectMethods.map(({ title, description }) => (
          <article class="py-2">
            <h3 class="mb-2 font-display font-semibold text-[19px] text-ink">
              {title}
            </h3>
            <p class="max-w-2xl text-slate leading-relaxed">{description}</p>
          </article>
        ))
      }
    </div>
  </Section>

  <Section>
    <h2>Why Acreage Owners Choose Wi-Fi Pros</h2>
    <ul class="mt-6 ml-4 space-y-3 text-slate">
      {
        whyChooseUs.map((reason) => (
          <li class="flex items-start gap-3 py-2 max-w-2xl">
            <Bullet class="mt-2" />
            <span>{reason}</span>
          </li>
        ))
      }
    </ul>
  </Section>

  <Section>
    <h2>Common Acreage Connectivity Scenarios We Solve</h2>
    <ul class="mt-6 ml-4 space-y-3 text-slate">
      {
        scenarios.map((scenario) => (
          <li class="flex items-start gap-3 py-2 max-w-2xl">
            <Bullet class="mt-2" />
            <span>{scenario}</span>
          </li>
        ))
      }
    </ul>
  </Section>

  <Section>
    <h2>Frequently Asked Questions</h2>
    <div class="mt-8 space-y-6">
      {
        faqs.map(({ question, answer }) => (
          <article class="py-2">
            <h3 class="mb-2 font-display font-semibold text-[19px] text-ink">
              {question}
            </h3>
            <p class="max-w-2xl text-slate leading-relaxed">{answer}</p>
          </article>
        ))
      }
    </div>
  </Section>

  <Section>
    <h2>Get a Free Rural Connectivity Assessment</h2>
    <p class="mt-3 max-w-2xl text-slate leading-relaxed">
      Every acreage is different. Tell us about your property — how many
      buildings, approximate distances, and what’s not working today — and we’ll
      recommend the right mix of wireless bridges, fibre, and Wi-Fi coverage.
    </p>
    <div class="mt-6 flex flex-wrap gap-4">
      <a
        href="/contact"
        class="bg-signal text-paper font-medium px-6 py-3 rounded-lg hover:bg-signal/90 transition-colors"
      >
        Get a Free Quote
      </a>
      <a
        href="/contact"
        class="border border-line text-ink font-medium px-6 py-3 rounded-lg hover:bg-ink/5 transition-colors"
      >
        Questions? Contact us!
      </a>
    </div>
  </Section>
</Layout>
